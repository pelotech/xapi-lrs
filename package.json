{
  "name": "xapi-lrs",
  "version": "0.8.2",
  "description": "xAPI Learning Record Store — standalone service for xAPI statement storage and document resources",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp -r src/admin/vendor dist/admin/vendor",
    "dev": "tsx watch src/server.ts",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint",
    "start": "node dist/server.js",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "test:conformance": "vitest run --project conformance",
    "test:conformance:2.0": "CONFORMANCE_XAPI_VERSION=2.0.0 vitest run --project conformance",
    "lint:deps": "depcruise src --config .dependency-cruiser.mjs",
    "lint:complexity": "fta src --config-path fta.json",
    "lint:arch": "pnpm lint:deps && pnpm lint:complexity",
    "typecheck": "tsc --noEmit",
    "db:migrate": "graphile-migrate migrate",
    "docker:build": "docker build -t xapi-lrs .",
    "docker-compose:up": "pnpm run dc up -d",
    "docker-compose:down": "pnpm run dc down",
    "dc": "docker compose",
    "dcu": "pnpm run dc up -d",
    "dcd": "pnpm run dc down",
    "docker-compose:pglite:up": "pnpm run dcp up -d",
    "docker-compose:pglite:down": "pnpm run dcp down",
    "dcp": "docker compose -f docker-compose.yml -f docker-compose.pglite.yml",
    "dcpu": "pnpm run dcp up -d",
    "dcpd": "pnpm run dcp down"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.0",
    "@hono/node-server": "^2.0.0",
    "@hono/zod-openapi": "^1.3.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "bcryptjs": "^3.0.3",
    "graphile-migrate": "2.0.0-rc.3",
    "hono": "^4.12.16",
    "jose": "^6.2.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.9.0",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "adl-lrs-conformance-tests": "github:adlnet/lrs-conformance-test-suite#5bc232d349c60faded8240da698f195106091638",
    "dependency-cruiser": "^18.0.0",
    "fta-cli": "^3.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.62.0",
    "tsx": "^4.21.0",
    "typescript": "7.0.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@11.11.0",
  "pnpm": {
    "overrides": {
      "adl-lrs-conformance-tests>super-request": "github:rchadwic/super-request#1c8e002a3babd42b59938b4e60474cfb8886130b",
      "adl-lrs-conformance-tests>supertest": "github:rchadwic/supertest#2a2346bc82d3c7233d363c265c5bf3b1be6ee5b2"
    }
  }
}
