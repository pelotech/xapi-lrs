{
  "name": "xapi-lrs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "tsoa:generate": "tsoa spec-and-routes",
    "build:rollup": "rollup --config rollup.config.ts --configPlugin @rollup/plugin-swc",
    "build": "pnpm tsoa:generate && pnpm build:rollup",
    "build:clean-docker-build-dir": "shx rm -rf ./.docker-build",
    "build:deploy-docker-build-dir": "pnpm build && pnpm build:clean-docker-build-dir && shx mkdir -p .docker-build && shx cp dist/main.js .docker-build/ && shx cp package.json .docker-build/ && shx cp Dockerfile .docker-build/ && cd .docker-build && pnpm install --prod --ignore-scripts",
    "build:docker": "pnpm build:deploy-docker-build-dir && cd ./.docker-build && docker build -f Dockerfile --tag xapi-lrs:local .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:conformance:xapi": "tsx test/conformance-runner.ts",
    "start": "node .",
    "start:local-dev": "cd src && dotenvx run -f ../.env.local-dev -- tsx watch --clear-screen=false main.ts",
    "migrate": "graphile-migrate migrate",
    "migrate:commit": "graphile-migrate commit",
    "migrate:uncommit": "graphile-migrate uncommit",
    "lint": "oxlint ${CI:+--format=github --quiet}",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "5.2.1",
    "pg": "^8.16.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-swc": "^0.4.0",
    "@swc/core": "~1.15.11",
    "@tsoa/runtime": "^6.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.12",
    "@types/pg": "^8.11.11",
    "cookie-parser": "^1.4.7",
    "cors": "2.8.6",
    "graphile-migrate": "^1.4.1",
    "jose": "^6.1.3",
    "oxlint": "^1.43.0",
    "prom-client": "^15.1.3",
    "rollup": "^4.57.1",
    "shx": "^0.4.0",
    "tsoa": "^6.6.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  }
}
