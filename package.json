{
  "name": "xapi-lrs",
  "version": "0.1.0",
  "description": "xAPI Learning Record Store — standalone service for xAPI statement storage and document resources",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint",
    "start": "node dist/server.js",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "test:conformance": "vitest run --project conformance",
    "lint:deps": "depcruise src --config .dependency-cruiser.mjs",
    "lint:complexity": "fta src --config-path fta.json",
    "lint:arch": "pnpm lint:deps && pnpm lint:complexity",
    "typecheck": "tsc --noEmit",
    "db:migrate": "graphile-migrate migrate",
    "docker:build": "docker build -t xapi-lrs .",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^1.3.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.215.0",
    "@opentelemetry/sdk-metrics": "^1.30.1",
    "graphile-migrate": "2.0.0-rc.3",
    "hono": "^4.12.16",
    "jose": "^6.2.3",
    "pg": "^8.20.0",
    "pino": "^8.21.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@typescript/native-preview": "7.0.0-dev.20260218.1",
    "adl-lrs-conformance-tests": "^1.2.3",
    "dependency-cruiser": "^17.3.10",
    "fta-cli": "^3.0.0",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.62.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.0-dev.20260218",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.29.1"
}
