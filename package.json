{
  "name": "xapi-lrs",
  "version": "0.0.1",
  "description": "xAPI Learning Record Store — standalone service for xAPI statement storage and document resources",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint",
    "start": "node dist/server.js",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "test:conformance": "CONFORMANCE=1 vitest run --project conformance",
    "typecheck": "tsc --noEmit",
    "db:migrate": "graphile-migrate migrate",
    "docker:build": "docker build -t xapi-lrs .",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@hono/zod-openapi": "^1.2.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-prometheus": "^0.57.2",
    "@opentelemetry/sdk-metrics": "^1.30.1",
    "hono": "^4.7.5",
    "jose": "^6.1.3",
    "pg": "^8.18.0",
    "pino": "^8.21.0",
    "uuidv7": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.10",
    "@types/pg": "^8.16.0",
    "@typescript/native-preview": "7.0.0-dev.20260218.1",
    "adl-lrs-conformance-tests": "^1.2.3",
    "graphile-migrate": "^2.0.0-rc.2",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.0-dev.20260218",
    "vitest": "^4.0.18"
  }
}
